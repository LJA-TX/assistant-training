    "schema_path": "string",
    "entry_count": "number",
    "family": "string",
    "index_id": "string",
    "status": "string",
    "last_verified": "string",
    "description": "string",
    "entries": "array",
    "stable_id": "string",
    "current_path": [
      "string",
      "null"
    ],
    "canonical_path": [
      "string",
      "null"
    ],
    "source_path": [
      "string",
      "null"
    ],
    "previous_paths": "array",
    "role": "string",
    "hash": [
      "string",
      "null"
    ],
    "provenance_note": "string",
    "related_ids": "array"
  },
  "id_patterns": {
    "registry_id": "^idx:registry:[0-9]{4}$",
    "family_index_id": "^idx:family:[a-z0-9_]+:[0-9]{4}$",
    "entry_stable_id": "^(conv|rpt|mfst|fix|samp|arc):[a-z0-9_]+:[0-9]{4}$"
